{
  "name": "@tjcages/shader-dev",
  "version": "1.0.0",
  "description": "Drop-in dev panel for tweaking shader uniforms live — sliders, color pickers, keyboard shortcut, copy/write JSON. Zero CSS framework, zero animation library.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "production": "./dist/index.prod.js",
      "development": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dev": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "shader",
    "webgl",
    "webgl2",
    "glsl",
    "three",
    "three.js",
    "react-three-fiber",
    "r3f",
    "uniforms",
    "dev-tools",
    "debug-panel",
    "tweakpane-alternative",
    "react"
  ],
  "author": "tjcages",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tjcages/shader-panel.git"
  },
  "homepage": "https://github.com/tjcages/shader-panel#readme",
  "bugs": {
    "url": "https://github.com/tjcages/shader-panel/issues"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
